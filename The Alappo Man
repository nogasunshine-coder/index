function renderResults() {
  const panel=document.getElementById('scorePanel'); panel.classList.add('show');
  const total = Object.values(scores).reduce((a,b)=>a+b,0);
  const pct = Math.round(total/MAX_TOTAL*100);
  document.getElementById('scoreBig').textContent=`${total}/${MAX_TOTAL}`;
