  bd.innerHTML=`
    <div class="score-item">Vocabulary<span>${scores.vocab}/5</span></div>
    <div class="score-item">Q1 (open)<span>${scores.q1}/4</span></div>
    <div class="score-item">Q2 True/False<span>${scores.tf}/6</span></div>
